                        "rawSql": "SELECT h.schema_name || '.' || h.table_name AS hypertable, h.num_dimensions, count(c.id) AS chunk_count, pg_size_pretty(sum(pg_total_relation_size(format('%I.%I', c.schema_name, c.table_name)))) AS total_size FROM _timescaledb_catalog.hypertable h LEFT JOIN _timescaledb_catalog.chunk c ON h.id = c.hypertable_id AND NOT c.dropped GROUP BY h.id, h.schema_name, h.table_name, h.num_dimensions"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
